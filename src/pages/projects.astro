---
import Layout from '../components/Layout.astro';
import ProjectCard from '../components/ProjectCard.astro';

const projects = Array.from({ length: 6 }, () => ({
  title: '[PROJECT TITLE PLACEHOLDER]',
  description: '[Short project description placeholder.]',
  tags: ['[Tag 1]', '[Tag 2]'],
}));
---

<Layout
  title="Projects — Pete McPherson"
  description="Pete McPherson — [placeholder]"
>
  <section class="section-padding">
    <div class="container-content">
      <h1 class="headline mb-20 text-5xl md:text-7xl">Projects</h1>

      <div class="grid gap-12 sm:grid-cols-2 lg:grid-cols-3">
        {
          projects.map((project) => (
            <ProjectCard
              title={project.title}
              description={project.description}
              tags={project.tags}
              variant="full"
            />
          ))
        }
      </div>
    </div>
  </section>
</Layout>
