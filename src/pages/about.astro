---
import Layout from '../components/Layout.astro';
import { bio, contact, education, person, whatIDo } from '../data/site';
---

<Layout
  title={`About — ${person.fullName}`}
  description={`About ${person.fullName}: analytics, SQL, Python, and GitHub projects.`}
>
  <section class="section-padding min-h-[60vh] flex flex-col justify-center border-b border-borderline/20">
    <div class="container-content fade-up">
      <h1 class="headline mb-12 text-7xl md:text-9xl leading-none text-foreground">About</h1>
      <p class="headline text-3xl md:text-5xl leading-snug max-w-4xl text-foreground">
        {bio.headline}
      </p>
    </div>
  </section>

  <section class="section-padding">
    <div class="container-content">
      <div class="grid gap-16 lg:grid-cols-[380px_1fr] lg:gap-24 fade-up">
        
        <!-- Redesigned Minimal Profile Column -->
        <div class="flex flex-col items-start shrink-0">
          <!-- Avatar Image Container -->
          <div class="relative w-full aspect-square overflow-hidden rounded-xl border border-[rgba(255,255,255,0.1)] bg-[#1a1a1a] mb-8">
            <img
              src={person.avatarUrl}
              alt={person.avatarAlt}
              class="w-full h-full object-cover"
              loading="eager"
            />
          </div>

          <!-- Name & Tagline -->
          <h2 class="font-display font-bold text-3xl mb-3 text-foreground tracking-tight leading-none">
            {person.fullName}
          </h2>
          <p class="font-body text-muted text-base mb-8 leading-relaxed">
            {person.tagline}
          </p>

          <!-- Social Links -->
          <div class="flex items-center gap-6 mb-4">
            <a href={person.githubUrl} class="text-accent hover:text-foreground transition-colors duration-300" aria-label="GitHub" target="_blank" rel="noopener noreferrer">
              <svg class="w-7 h-7" fill="currentColor" viewBox="0 0 24 24"><path fill-rule="evenodd" clip-rule="evenodd" d="M12 2C6.477 2 2 6.477 2 12c0 4.42 2.865 8.166 6.839 9.489.5.092.682-.217.682-.482 0-.237-.008-.866-.013-1.7-2.782.603-3.369-1.34-3.369-1.34-.454-1.156-1.11-1.462-1.11-1.462-.908-.62.069-.608.069-.608 1.003.07 1.531 1.03 1.531 1.03.892 1.529 2.341 1.087 2.91.831.092-.646.35-1.086.636-1.336-2.22-.253-4.555-1.11-4.555-4.943 0-1.091.39-1.984 1.029-2.683-.103-.253-.446-1.27.098-2.647 0 0 .84-.269 2.75 1.025A9.578 9.578 0 0112 6.836c.85.004 1.705.114 2.504.336 1.909-1.294 2.747-1.025 2.747-1.025.546 1.377.203 2.394.1 2.647.64.699 1.028 1.592 1.028 2.683 0 3.842-2.339 4.687-4.566 4.935.359.309.678.919.678 1.852 0 1.336-.012 2.415-.012 2.743 0 .267.18.578.688.48C19.138 20.161 22 16.418 22 12c0-5.523-4.477-10-10-10z"/></svg>
            </a>
            {contact.linkedinUrl && (
              <a href={contact.linkedinUrl} class="text-accent hover:text-foreground transition-colors duration-300" aria-label="LinkedIn" target="_blank" rel="noopener noreferrer">
                <svg class="w-7 h-7" fill="currentColor" viewBox="0 0 24 24"><path fill-rule="evenodd" clip-rule="evenodd" d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/></svg>
              </a>
            )}
          </div>
        </div>

        <!-- Bio Content -->
        <div class="flex flex-col gap-10">
          <div class="space-y-6">
            {bio.paragraphs.map((p) => (
              <p class="font-body text-xl leading-relaxed text-muted">{p}</p>
            ))}
          </div>

          <div class="border border-borderline/20 p-8 mt-4">
            <p class="headline text-2xl mb-6 text-foreground">Recruiter Snapshot</p>
            <ul class="list-none space-y-4 font-body text-lg text-foreground">
              <li class="flex items-center gap-4">
                <span class="font-display font-bold uppercase tracking-widest text-xs w-24 shrink-0 border-r border-borderline/20">GitHub</span>
                <a
                  href={person.githubUrl}
                  class="text-accent hover:text-foreground transition-colors duration-300 normal-case"
                  target="_blank"
                  rel="noopener noreferrer"
                >
                  @{person.githubUsername}
                </a>
              </li>
              {
                contact.email && (
                  <li class="flex items-center gap-4">
                    <span class="font-display font-bold uppercase tracking-widest text-xs w-24 shrink-0 border-r border-borderline/20">Email</span>
                    <a href={`mailto:${contact.email}`} class="text-accent hover:text-foreground transition-colors duration-300 normal-case">
                      {contact.email}
                    </a>
                  </li>
                )
              }
              {
                contact.linkedinUrl && (
                  <li class="flex items-center gap-4">
                    <span class="font-display font-bold uppercase tracking-widest text-xs w-24 shrink-0 border-r border-borderline/20">LinkedIn</span>
                    <a
                      href={contact.linkedinUrl}
                      class="text-accent hover:text-foreground transition-colors duration-300 normal-case"
                      target="_blank"
                      rel="noopener noreferrer"
                    >
                      Profile ↗
                    </a>
                  </li>
                )
              }
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="border-t border-borderline/20 section-padding">
    <div class="container-content max-w-4xl fade-up">
      <h2 class="headline mb-16 text-5xl md:text-7xl text-foreground">What I Do</h2>
      <div class="flex flex-col border-t border-borderline/20">
        {
          whatIDo.map((skill, i) => (
            <div class="flex flex-col md:flex-row gap-6 md:gap-12 border-b border-borderline/20 py-10 px-6 -mx-6">
              <span class="headline text-3xl md:text-4xl text-accent shrink-0">0{i + 1}</span>
              <p class="font-body text-xl md:text-2xl text-foreground leading-relaxed">{skill}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>
</Layout>
