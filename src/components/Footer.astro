---
import { person } from '../data/site';

const links = [
  { href: '/', label: 'Home' },
  { href: '/about', label: 'About' },
  { href: '/projects', label: 'Projects' },
];
---

<footer class="border-t border-black bg-white">
  <div class="container-content section-padding">
    <div class="flex flex-col gap-10 md:flex-row md:items-start md:justify-between md:gap-16">
      <nav aria-label="Footer navigation">
        <ul class="flex flex-wrap gap-6">
          {
            links.map((link) => (
              <li>
                <a
                  href={link.href}
                  class="headline text-sm text-black transition-colors duration-200 hover:text-red"
                >
                  {link.label}
                </a>
              </li>
            ))
          }
        </ul>
      </nav>
      <div class="flex flex-col gap-6 md:items-end">
        <p class="font-body text-sm text-black md:text-right">
          &copy; {new Date().getFullYear()} {person.fullName}
        </p>
        <a
          href={person.githubUrl}
          class="link-red w-fit md:self-end"
          target="_blank"
          rel="noopener noreferrer"
        >
          GitHub → @{person.githubUsername}
        </a>
        <a href="#top" class="link-red w-fit md:self-end">
          Back to top &uarr;
        </a>
      </div>
    </div>
  </div>
</footer>
