---
import { person } from '../data/site';

const currentPath = Astro.url.pathname;

const links = [
  { href: '/', label: 'Home' },
  { href: '/about', label: 'About' },
  { href: '/projects', label: 'Projects' },
];

function isActive(href: string): boolean {
  if (href === '/') return currentPath === '/';
  return currentPath.startsWith(href);
}
---

<header class="sticky top-0 z-50 border-b border-black bg-white">
  <div class="container-content flex flex-col gap-4 px-6 py-6 md:flex-row md:items-center md:justify-between md:px-12">
    <a
      href="/"
      class="headline text-xl text-black transition-colors duration-200 hover:text-red"
    >
      {person.fullName}
    </a>
    <nav aria-label="Main navigation">
      <ul class="flex flex-col gap-3 sm:flex-row sm:gap-8">
        {
          links.map((link) => (
            <li>
              <a
                href={link.href}
                class:list={[
                  'headline text-sm transition-colors duration-200',
                  isActive(link.href)
                    ? 'text-red'
                    : 'text-black hover:text-red',
                ]}
                aria-current={isActive(link.href) ? 'page' : undefined}
              >
                {link.label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>
  </div>
</header>
