---
import { person } from '../data/site';

const currentPath = Astro.url.pathname;

const links = [
  { href: '/', label: 'Home' },
  { href: '/about', label: 'About' },
  { href: '/projects', label: 'Projects' },
];

function isActive(href: string): boolean {
  if (href === '/') return currentPath === '/';
  return currentPath.startsWith(href);
}
---

<header class="sticky top-0 z-50 bg-background">
  <div class="container-content flex items-center justify-between px-6 py-6 md:px-12 border-b border-borderline/20">
    <a
      href="/"
      class="headline text-xl md:text-2xl text-foreground transition-all duration-300 hover:text-accent"
    >
      {person.fullName}
    </a>
    <nav aria-label="Main navigation">
      <ul class="flex flex-row items-center gap-6 md:gap-10">
        {
          links.map((link) => (
            <li>
              <a
                href={link.href}
                class:list={[
                  'headline text-sm md:text-base transition-all duration-300',
                  isActive(link.href)
                    ? 'text-accent'
                    : 'text-foreground hover:text-accent inline-block',
                ]}
                aria-current={isActive(link.href) ? 'page' : undefined}
              >
                {link.label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>
  </div>
</header>
