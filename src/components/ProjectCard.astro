---
interface Props {
  title: string;
  description: string;
  tags?: string[];
  href?: string;
  live?: string;
  image?: string;
  mainTech?: string;
  variant?: 'teaser' | 'full';
  /** Opens GitHub etc. in a new tab */
  external?: boolean;
  delay?: number;
}

const {
  title,
  description,
  tags = [],
  href = '#',
  live,
  image,
  mainTech,
  variant = 'full',
  external = false,
  delay = 0,
} = Astro.props;

const anchorAttrs = external
  ? { target: '_blank' as const, rel: 'noopener noreferrer' }
  : {};

const linkText = variant === 'teaser' ? 'View Details' : 'View Project';
---

<article class="group flex flex-col h-full border border-borderline/20 bg-transparent p-6 md:p-8 hover:border-accent/40 fade-up" style={`transition-delay: ${delay * 100}ms`}>
  <div class="flex flex-col h-full">
    <a href={href} class="flex flex-col outline-none mb-6" {...anchorAttrs}>
      {
        variant === 'full' && (
          <div class="relative mb-8 w-full overflow-hidden rounded-lg border border-[rgba(255,255,255,0.08)] bg-[#1a1a1a] aspect-[16/10] flex items-center justify-center">
             {image ? (
               <img src={image} alt={`${title} preview`} class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-[1.03]" loading="lazy" />
             ) : (
               <div class="w-full h-full bg-[#1a1a1a] transition-all duration-500 group-hover:bg-[#222]"></div>
             )}
             
             {mainTech && (
               <div class="absolute bottom-3 left-3 bg-[#111]/80 backdrop-blur-sm border border-white/10 px-2.5 py-1 rounded text-xs font-display font-bold uppercase tracking-widest text-foreground flex items-center shadow-sm z-10">
                 {mainTech}
               </div>
             )}

             {live && (
               <div class="absolute top-3 right-3 bg-[#111]/80 backdrop-blur-sm border border-white/10 px-2.5 py-1.5 rounded-full text-[10px] font-display font-bold uppercase tracking-widest text-foreground flex items-center gap-1.5 shadow-sm z-10">
                 <span class="w-2 h-2 rounded-full bg-orange-500 animate-pulse"></span>
                 Live
               </div>
             )}
          </div>
        )
      }
      <h3 class="headline mb-3 text-2xl lg:text-3xl text-foreground transition-colors duration-300 group-hover:text-accent">{title}</h3>
      <p class="font-body text-base text-muted leading-relaxed">{description}</p>
    </a>
    
    <div class="mt-auto flex flex-col gap-4 items-start border-t border-borderline/20 pt-6">
      {
        tags.length > 0 && (
          <p class="font-display text-xs font-bold uppercase tracking-widest text-foreground">
            {tags.join(', ')}
          </p>
        )
      }
      <div class="flex items-center gap-6">
        <a href={href} class="font-display text-sm font-bold tracking-display text-accent flex items-center gap-2 transition-colors duration-300 hover:text-foreground" {...anchorAttrs}>
          {linkText} <span class="transition-transform duration-300 group-hover:translate-x-1">→</span>
        </a>
        {
          live && (
            <a href={live} class="font-display text-sm font-bold tracking-display text-accent flex items-center gap-2 transition-colors duration-300 hover:text-foreground" target="_blank" rel="noopener noreferrer">
              Live Demo <span class="transition-transform duration-300 group-hover:translate-x-1">↗</span>
            </a>
          )
        }
      </div>
    </div>
  </div>
</article>
